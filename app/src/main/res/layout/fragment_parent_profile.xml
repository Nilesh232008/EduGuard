<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F5F7FB"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:padding="16dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- STUDENT NAME -->
        <TextView
            android:id="@+id/tvStudentName"
            android:text="Student Name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- RISK LINE GRAPH -->
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/riskLineChart"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="260dp"/>

        <!-- PIE CHARTS ROW -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:weightSum="2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ATTENDANCE -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/attendancePie"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="220dp"
                android:layout_marginEnd="8dp"/>

            <!-- HOMEWORK -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/homeworkPie"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="220dp"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <!-- RISK REASON CARD -->
        <androidx.cardview.widget.CardView
            android:layout_marginTop="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="⚠ Risk Reason"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#DC2626"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvRiskReason"
                    android:text="Reason appears here"
                    android:layout_marginTop="8dp"
                    android:textColor="#374151"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- IMPROVEMENT TIPS CARD -->
        <androidx.cardview.widget.CardView
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="✅ Improvement Tips"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#16A34A"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvTips"
                    android:text="Tips appear here"
                    android:layout_marginTop="8dp"
                    android:textColor="#374151"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>