<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#F5F7FB"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:padding="16dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- STUDENT NAME -->
        <TextView
            android:id="@+id/tvStudentName"
            android:text="Student Name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>


        <!-- RISK METER -->
        <com.github.anastr.speedviewlib.SpeedView
            android:id="@+id/speedView"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            app:sv_speedTextSize="24sp"
            app:sv_unit="Risk"/>


        <!-- PIE CHARTS ROW -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:weightSum="2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ATTENDANCE -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/attendancePie"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="200dp"/>

            <!-- HOMEWORK -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/homeworkPie"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="200dp"/>

        </LinearLayout>


        <!-- RISK REASON -->
        <androidx.cardview.widget.CardView
            android:layout_marginTop="20dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Risk Reason"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvRiskReason"
                    android:text="Reason appears here"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>


        <!-- IMPROVEMENT TIPS -->
        <androidx.cardview.widget.CardView
            android:layout_marginTop="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Improvement Tips"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvTips"
                    android:text="Tips appear here"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
