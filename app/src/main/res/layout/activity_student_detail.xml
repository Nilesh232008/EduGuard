<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/tvName"
        android:textSize="20sp"
        android:text="Name"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/tvClass"
        android:text="Class"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/etAssignments"
        android:hint="Assignments Completed"
        android:layout_width="match_parent"
        android:layout_height="50dp"/>

    <EditText
        android:id="@+id/etMarks"
        android:hint="Marks (out of 100)"
        android:layout_width="match_parent"
        android:layout_height="50dp"/>

    <EditText
        android:id="@+id/etBehavior"
        android:hint="Behavior (1-5)"
        android:layout_width="match_parent"
        android:layout_height="50dp"/>

    <Switch
        android:id="@+id/switchFees"
        android:text="Fees Paid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>